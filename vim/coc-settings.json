{
  "languageserver": {
    "clangd": {
      "command": "clangd",
      "rootPatterns": [
        "compile_flags.txt",
        "compile_commands.json",
        ".vim/",
        ".git/",
        ".hg/"
      ],
      "filetypes": ["c", "cpp", "objc", "objcpp"]
    },
    "golang": {
      "command": "gopls",
      "args": [],
      "rootPatterns": ["go.mod", ".vim/", ".git/", ".hg/"],
      "filetypes": ["go"]
    },
    "dockerfile": {
      "command": "docker-langserver",
      "filetypes": ["dockerfile"],
      "args": ["--stdio"]
    },
    "efm": {
      "command": "efm-langserver",
      "args": [],
      // custom config path
      // "args": ["-c", "/path/to/your/config.yaml"],
      "filetypes": ["vim", "eruby", "markdown"]
    },
    "haskell": {
      "command": "hie-wrapper",
      "rootPatterns": [".stack.yaml", "cabal.config", "package.yaml"],
      "filetypes": ["hs", "lhs", "haskell"],
      "initializationOptions": {
        "languageServerHaskell": {
          "hlintOn": true
        }
      }
    },
     "dart": {
      "command": "dart", // in windows is dart_language_server.bat
      "args": ["/opt/dart-sdk/bin/snapshots/analysis_server.dart.snapshot","--lsp"],
      "filetypes": ["dart"],
      "initializationOptions": {
        "closingLabels": true
      },
      "settings": {
        "dart": {
          "validation": {},
          "completion": {}
        }
      }
    }
  },
  "coc.source.around.enable": false,
  "coc.source.buffer.enable": false,
  "list.source.files.excludePatterns": [
    "**/.git/*",
    "/tmp/*",
    "**/target/*",
    "**/dist/*"
  ]
}
