# update colors
eval $(dircolors -b)
export ZLSCOLORS="${LS_COLORS}"
zmodload zsh/complist
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
zstyle ':completion:*:*:kill:*:processes' list-colors '=(#b) #([0-9]#)*=0=01;31'


alias ls="ls --color=auto"

eval "$(starship init zsh)"


eval "$(atuin init zsh --disable-up-arrow)"
autoload -U compinit; compinit


# ByteDance
check_bytedance() {
    # 检查是否是 macOS 系统
    if [ "$(uname)" != "Darwin" ]; then
        export IS_BYTEDANCE=0
    fi

    # 在 macOS 上检查 CA 证书
    if security find-certificate -a | grep -q "ByteDance"; then
        export IS_BYTEDANCE=1
    else
        export IS_BYTEDANCE=0
    fi
}

if [ check_bytedance ]; then
    echo "We Are In ByteDance!"
    [ -f "$HOME/.bytebm/config/config.sh" ] && . "$HOME/.bytebm/config/config.sh"
fi
# ByteDance End

